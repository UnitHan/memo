{
  "productName": "AI-Memo",
  "version": "1.1.1",
  "identifier": "com.qabulls.ai-memo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "../icon.png",
      "../icon.ico",
      "../icon.icns"
    ],
    "externalBin": [
      "binaries/gemini-corrector"
    ],
    "resources": [
      "binaries/*"
    ]
  }
}
