{
  "productName": "AI 메모장",
  "version": "1.0.0",
  "identifier": "com.qabulls.ai-memo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI 메모장",
        "width": 320,
        "height": 450,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": false,
        "x": 100,
        "y": 100,
        "dragDropEnabled": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "../icon.png",
      "../icon.ico",
      "../icon.icns"
    ],
    "externalBin": [
      "binaries/gemini-corrector"
    ],
    "resources": [
      "binaries/*"
    ]
  }
}
